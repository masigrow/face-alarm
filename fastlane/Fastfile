default_platform(:ios)

platform :ios do

  desc "Sync certificates (read-only)"
  lane :certs do
    match(type: "appstore", readonly: true)
  end

  desc "Run tests"
  lane :tests do
    run_tests(
      project: "FaceAlarm.xcodeproj",
      scheme: "FaceAlarm",
      devices: ["iPhone 16"]
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # Bump build number to current timestamp
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M")
    )

    build_app(
      project: "FaceAlarm.xcodeproj",
      scheme: "FaceAlarm",
      export_method: "app-store"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit to App Store"
  lane :release do
    match(type: "appstore", readonly: true)

    build_app(
      project: "FaceAlarm.xcodeproj",
      scheme: "FaceAlarm",
      export_method: "app-store"
    )

    upload_to_app_store(
      skip_screenshots: false,
      skip_metadata: false,
      submit_for_review: false   # manual trigger for first submission
    )
  end

end
